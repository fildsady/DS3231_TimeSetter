<Window x:Class="DS3231_TimeSetter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="DS3231 RTC + GPIO (HID)" Height="560" Width="460" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Theme + Connect -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <ComboBox x:Name="cmbTheme" DockPanel.Dock="Right" Width="120" SelectionChanged="CmbTheme_Changed">
                <ComboBoxItem Content="System" IsSelected="True"/>
                <ComboBoxItem Content="Light"/>
                <ComboBoxItem Content="Dark"/>
            </ComboBox>
            <Button x:Name="btnConnect" Content="Connect" Width="100" Height="32" Click="BtnConnect_Click"/>
            <TextBlock x:Name="txtStatus" Text="Disconnected" VerticalAlignment="Center" Margin="12,0" Foreground="Gray"/>
        </DockPanel>

        <!-- PC Time -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="PC Time:" VerticalAlignment="Center" Width="70"/>
            <TextBlock x:Name="txtPcTime" Text="--:--:--" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource SystemAccentColorLight2Brush}"/>
        </StackPanel>

        <!-- RTC Time -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="RTC Time:" VerticalAlignment="Center" Width="70"/>
            <TextBlock x:Name="txtRtcTime" Text="--:--:--" FontSize="20" FontWeight="SemiBold" Foreground="LimeGreen"/>
            <TextBlock x:Name="txtTemp" Text="" FontSize="14" VerticalAlignment="Center" Margin="12,0,0,0"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
        </StackPanel>

        <!-- Time Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,12">
            <Button x:Name="btnSyncTime" Content="Sync PC Time → RTC" Width="170" Height="36" FontSize="14"
                    Click="BtnSyncTime_Click" IsEnabled="False" Style="{StaticResource AccentButtonStyle}"/>
            <Button x:Name="btnReadTime" Content="Read RTC" Width="100" Height="36" FontSize="14" Margin="8,0"
                    Click="BtnReadTime_Click" IsEnabled="False"/>
        </StackPanel>

        <!-- LED Control -->
        <GroupBox Grid.Row="4" Header="LED Output (GP10-13)" Margin="0,0,0,8" IsEnabled="False" x:Name="grpLed">
            <StackPanel Orientation="Horizontal" Margin="4">
                <CheckBox x:Name="chkLed0" Content="LED 0 (GP10)" Margin="0,0,16,0" Click="Led_Click"/>
                <CheckBox x:Name="chkLed1" Content="LED 1 (GP11)" Margin="0,0,16,0" Click="Led_Click"/>
                <CheckBox x:Name="chkLed2" Content="LED 2 (GP12)" Margin="0,0,16,0" Click="Led_Click"/>
                <CheckBox x:Name="chkLed3" Content="LED 3 (GP13)" Click="Led_Click"/>
            </StackPanel>
        </GroupBox>

        <!-- Input Status -->
        <GroupBox Grid.Row="5" Header="Digital Input (GP20-22)" Margin="0,0,0,8" IsEnabled="False" x:Name="grpInput">
            <StackPanel Orientation="Horizontal" Margin="4">
                <Border x:Name="indIn0" Width="16" Height="16" CornerRadius="8" Background="Gray" Margin="0,0,4,0"/>
                <TextBlock Text="IN0 (GP20)" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Border x:Name="indIn1" Width="16" Height="16" CornerRadius="8" Background="Gray" Margin="0,0,4,0"/>
                <TextBlock Text="IN1 (GP21)" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Border x:Name="indIn2" Width="16" Height="16" CornerRadius="8" Background="Gray" Margin="0,0,4,0"/>
                <TextBlock Text="IN2 (GP22)" VerticalAlignment="Center"/>
            </StackPanel>
        </GroupBox>

        <!-- Spacer -->
        <TextBlock Grid.Row="6"/>

        <!-- Log -->
        <TextBox Grid.Row="7" x:Name="txtLog" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                 TextWrapping="Wrap" Margin="0,4,0,0" FontFamily="Consolas" FontSize="11"/>
    </Grid>
</Window>
